ACME_EMAIL=admin@example.com

# Optional. Use Let's Encrypt staging while testing to avoid production rate limits.
# ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory

# Optional renewal behavior.
RENEW_BEFORE_DAYS=30
CHECK_INTERVAL_SECS=43200
DNS_WAIT_SECS=90

# Each certificate group uses CERT_N_DOMAINS and CERT_N_KEY.
# CERT_N_KEY is the plain West.cn domain API password; rustacme hashes it as MD5(GBK(password)).
CERT_1_DOMAINS=example.com,*.example.com
CERT_1_KEY=replace-with-west-domain-api-key

# CERT_2_DOMAINS=example.net,*.example.net
# CERT_2_KEY=replace-with-west-domain-api-key
